# Docker Compose Environment Variables
# Copy this file to .env and adjust values as needed

# Frontend path (if different from default)
# FRONTEND_PATH=../demo-front

# MySQL Init Folder - Choose which dataset to load
# Available options:
# - init (default) - Full demo dataset with worldcup matches and sample data
# - init-extended   - Extended dataset with 40 users, 20 matches, diverse predictions
# Example: MYSQL_INIT_FOLDER=init-extended
MYSQL_INIT_FOLDER=init

# CORS Configuration
# Add additional allowed origins for remote access (comma-separated)
# Examples:
# - For single IP: CORS_ALLOWED_ORIGINS=http://192.168.0.18:3000
# - For multiple IPs: CORS_ALLOWED_ORIGINS=http://192.168.0.18:3000,http://192.168.1.100:3000
# - For hostname: CORS_ALLOWED_ORIGINS=http://my-server:3000
CORS_ALLOWED_ORIGINS=
