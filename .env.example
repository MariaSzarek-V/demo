# Docker Compose Environment Variables
# Copy this file to .env and adjust values as needed

# Frontend path (if different from default)
# FRONTEND_PATH=../demo-front

# CORS Configuration
# Add additional allowed origins for remote access (comma-separated)
# Examples:
# - For single IP: CORS_ALLOWED_ORIGINS=http://192.168.0.18:3000
# - For multiple IPs: CORS_ALLOWED_ORIGINS=http://192.168.0.18:3000,http://192.168.1.100:3000
# - For hostname: CORS_ALLOWED_ORIGINS=http://my-server:3000
CORS_ALLOWED_ORIGINS=
